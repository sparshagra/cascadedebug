training/checkpoints/
*.bin
*.safetensors
*.pt
*.ckpt

# Colab / Jupyter
.ipynb_checkpoints/

# Results: COMMIT .png plots, ignore everything else
!results/*.png
!results/*.jpg
results/*.csv
results/tmp/
